# Build output
bin/
obj/

# Generated interactive-demo gallery (scripts/gen-demos.sh / .github/workflows/demos.yml) — always
# regenerated, never committed. See docs/DEMOS.md.
/site/

# NuGet
*.nupkg
.nuget/
packages/

# Local SUMO install (network-side, never committed — see CLAUDE.md)
.sumo/
sumo-local/

# IDE / OS
.vs/
.vscode/
*.user
.DS_Store

# Benchmark (BENCHMARK_SPEC.md / VIZ_BENCH_TASKS.md VB-5..VB-8): the engine's own tripinfo/
# summary/FCD analogs are regenerated by `dotnet run --project src/Sim.BenchCity` and are NEVER
# committed (only the SUMO reference summary/tripinfo + provenance + small-rung replay.html are
# committed goldens -- see scenarios/_bench/city-*/provenance.txt and VB-8's "committed vs
# regenerated" list). Large rungs' FCD is regenerate-on-demand, never committed, per the same rule.
scenarios/_bench/city-*/engine.fcd.xml
scenarios/_bench/city-*/engine.summary.xml
scenarios/_bench/city-*/engine.tripinfo.xml
scenarios/_bench/city-organic-L2/replay.html
scenarios/_bench/city-mixed-1k/replay.html

# Sim.ExtDemo (external-agent visual test): the combined FCD and its replay.html are regenerated
# on demand (`dotnet run --project src/Sim.ExtDemo` / `src/Sim.Viz`), never committed -- only the
# scenario inputs (net/rou/config/external-agents.json) and NOTES.md/provenance.txt are.
scenarios/_bench/ext-agents-demo/engine.fcd.xml
scenarios/_bench/ext-agents-demo/replay.html
scenarios/_bench/ext-agents-demo/playwright_screenshot.png
scenarios/_bench/ext-swerve-demo/replay.html
scenarios/_bench/ext-swerve-demo/combined.fcd.xml
scenarios/_bench/ext-agents-demo/combined.fcd.xml
scenarios/_bench/ext-showcase/engine.fcd.xml
scenarios/_bench/ext-showcase/replay.html
scenarios/_bench/ext-showcase/combined.fcd.xml
scenarios/_bench/ext-showcase/playwright_screenshot.png

# Rail level-crossing + emergency rescue-lane demos: regenerated engine FCD and replay.
scenarios/_bench/rail-crossing-demo/engine.fcd.xml
scenarios/_bench/rail-crossing-demo/replay.html
scenarios/_bench/emergency-corridor-demo/engine.fcd.xml
scenarios/_bench/emergency-corridor-demo/replay.html

# Benchmark / scaling script outputs (regenerated, never committed)
scaling-results.csv
# Accidental FCD dump from a mis-redirected --fcd-out (was a 504 MB file named "--serial")
/--serial

# Local visualizer/engine artifacts produced by scripts/run-examples.sh (a few pre-rendered replays
# are committed intentionally; everything these scripts regenerate is local-only).
scenarios/**/replay.html
scenarios/**/engine.fcd.xml
scenarios/**/combined.fcd.xml

# Dear ImGui writes its window layout here (native viewer, Sim.Viewer); local-only.
imgui.ini
# CycloneDDS writes a runtime log to the CWD on viewer DDS runs (loopback/publish/remote); local-only.
cyclonedds.log
