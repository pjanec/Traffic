; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are meant to be edited.
;
; format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="City3D Viewer"
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.7", "C#")
config/icon=""

[dotnet]

project/assembly_name="Viewer"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
; 4x MSAA -- smooths the jagged/crawling 3D box + road edges (huge visual win, per testing).
; Values: 0=off, 1=2x, 2=4x (sweet spot), 3=8x. Works under gl_compatibility.
; FXAA (anti_aliasing/quality/screen_space_aa=1) is an optional extra but softens HUD text, so left off.
; TAA would best cure moving-edge crawl but needs the forward_plus renderer (this viewer is gl_compatibility).
anti_aliasing/quality/msaa_3d=2
