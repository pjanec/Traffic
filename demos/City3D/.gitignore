# Ephemeral — regenerated by build.sh / the Godot toolchain, never committed
# (committed-vs-ephemeral rule). NOTE: gitignore has no trailing inline comments;
# each pattern is on its own line.

# the local NuGet feed populated by build.sh (dotnet pack output)
local-nuget/

# Godot's import cache / generated project data
.godot/

# build output
bin/
obj/

# Godot export output
export/

*.tmp

# ephemeral Godot engine (fetch-godot.sh defaults to /opt/godot, outside the repo)
.godot-engine/
