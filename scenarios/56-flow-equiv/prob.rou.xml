<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- F2 fixture (probabilistic form). A single probability flow on the same 500 m single lane:
         each second, insert a passenger car with probability 0.15 over [0, 60). Arrivals are decided
         at runtime by a per-flow seeded RNG (NOT expanded at load), so the vehicle set is
         deterministic given the engine seed but not a fixed schedule. RungF2ProbabilisticFlowTests
         asserts the run is deterministic/reproducible, the arrival rate is in the expected band, the
         in-memory WarmUp warm-start carries the stream continuously, and the file snapshot is guarded
         while a flow is still active. No SUMO golden (SUMO-stream statistical parity is the deferred
         network cross-check). -->
    <vType id="car" vClass="passenger" sigma="0"/>
    <route id="r0" edges="e0"/>
    <flow id="p" type="car" route="r0" begin="0" end="60" probability="0.15"
          departPos="0" departSpeed="0" departLane="0"/>
</routes>
