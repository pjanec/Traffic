<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- D3 fixture: a fast lcOpposite overtaker held up behind a slow leader, with a normal oncoming
         approaching head-on CLOSE enough that the conservative (complete-and-return-before-arrival)
         gap acceptance would abort the overtake. On this WIDE lane (3.8 m) the oncoming cooperatively
         shifts to its outer edge (OV4) and the coupled gap acceptance (D3) lets the overtaker keep
         its commitment and pass the leader SIDE BY SIDE with the oncoming, then both recentre. The
         test asserts the overtaker does not abort, the closest head-on approach happens with both
         vehicles off-centre and a safe lateral corridor, no pair collides, and both recentre.
         (On the narrow 3.2 m lane of scenario 57 the corridor is negative, so D3 never engages and
         those fixtures stay byte-identical.) -->
    <vType id="slow" vClass="passenger" sigma="0" maxSpeed="6"/>
    <vType id="fast" vClass="passenger" sigma="0" maxSpeed="13.89" lcOpposite="true"/>
    <vType id="onc"  vClass="passenger" sigma="0" maxSpeed="13.89"/>
    <route id="ab" edges="AB"/>
    <route id="ba" edges="BA"/>
    <vehicle id="leader"    type="slow" route="ab" depart="0" departPos="100" departSpeed="0" departLane="0"/>
    <vehicle id="overtaker" type="fast" route="ab" depart="0" departPos="60"  departSpeed="0" departLane="0"/>
    <vehicle id="oncoming"  type="onc"  route="ba" depart="0" departPos="740" departSpeed="0" departLane="0"/>
</routes>
