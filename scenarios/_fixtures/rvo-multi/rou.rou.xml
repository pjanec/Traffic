<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- three slow vehicles queued centred ahead + one fast follower. The RVO radius query gathers
         all near neighbours at once; the fast car drifts to one side and overtakes the whole queue,
         staying clear of every one of them. No golden (behavioural). -->
    <vType id="slow" vClass="passenger" sigma="0" maxSpeed="5"/>
    <vType id="fast" vClass="passenger" sigma="0"/>
    <route id="r0" edges="e0"/>
    <vehicle id="s0" type="slow" route="r0" depart="0" departPos="40" departSpeed="0"/>
    <vehicle id="s1" type="slow" route="r0" depart="0" departPos="55" departSpeed="0"/>
    <vehicle id="s2" type="slow" route="r0" depart="0" departPos="70" departSpeed="0"/>
    <vehicle id="f"  type="fast" route="r0" depart="0" departPos="0"  departSpeed="0"/>
</routes>
